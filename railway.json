{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "nixpacks",
        "watchPatterns": [
            "/python_backend/**"
        ]
    },
    "deploy": {
        "startCommand": "cd python_backend && python -m uvicorn main:app --host 0.0.0.0 --port $PORT",
        "restartPolicyType": "ON_FAILURE"
    }
}