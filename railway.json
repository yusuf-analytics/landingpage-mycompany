{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "providers": [
                "python"
            ],
            "phases": {
                "setup": {
                    "nixPkgs": [
                        "python311"
                    ]
                },
                "install": {
                    "cmds": [
                        "cd python_backend && pip install -r requirements.txt"
                    ]
                }
            }
        }
    },
    "deploy": {
        "startCommand": "cd python_backend && uvicorn main:app --host 0.0.0.0 --port $PORT",
        "restartPolicyType": "ON_FAILURE"
    }
}